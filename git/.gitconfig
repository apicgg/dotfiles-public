[user]
	email = p.anurag@outlook.com
	name = Anurag Pramanik
[gpg]
	program = /opt/homebrew/bin/gpg
[commit]
	gpgsign = true
[tag]
	gpgsign = true
[init]
	defaultBranch = main
[core]
  excludesfile = ~/.gitignore_global
  # editor = code --wait
  editor = vim
[push]
  default = simple
[github]
  user = apicgg
[color]
  status = auto
  diff = auto
  branch = auto
  interactive = auto
  grep = auto
  ui = auto
[alias]
  cl = clone
  st = status
  cm = commit
  cma = commit -a
  co = checkout
  cob = checkout -b
  ps = push
  pnb = "!git push --set-upstream origin $(git rev-parse --abbrev-ref HEAD)"
  pl = pull
  d = diff
  df = diff -b --color-words
  dfw = diff -w
  dfs = diff -w --staged
  br = branch
  ba = branch -a
  l = log
  lg = log --graph --name-status --pretty=format:\"%C(red)%h %C(reset)(%cd) %C(green)%an %Creset%s %C(yellow)%d%Creset\" --date=relative
  fl = log --pretty=full --stat