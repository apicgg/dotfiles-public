// Place your key bindings in this file to override the defaults
[
  {
    "command": "projectManager.listGitProjects#sideBarGit",
    "key": "cmd+o"
  },
  {
    "command": "-extension.vim_ctrl+g",
    "key": "ctrl+g",
    "when": "editorTextFocus && vim.active && vim.use<C-g> && !inDebugRepl"
  }
]
